@OptIn(ExperimentalMaterial3Api::class)
class MainActivity : ComponentActivity() {
    override fun onCreate(savedInstanceState: Bundle?) {
        super.onCreate(savedInstanceState)
        enableEdgeToEdge()

        setContent {
            PrakTam2_2457051010Theme {

                Scaffold(
                    topBar = {
                        TopAppBar(
                            title = { Text("LaundryKu - Sistem Laundry") }
                        )
                    }
                ) { innerPadding ->

                    LaundryScreen(
                        modifier = Modifier.padding(innerPadding)
                    )

                }
            }
        }
    }
}

data class LaundryService(
    val nama: String,
    val harga: String,
    val deskripsi: String,
    val imageRes: Int,
    val isBestSeller: Boolean = false
)

@Composable
fun LaundryScreen(modifier: Modifier = Modifier) {

    val listLaundry = listOf(
        LaundryService("Cuci Kering","Rp 7.000/kg","Layanan cuci dan pengeringan tanpa setrika.",R.drawable.cucikering),
        LaundryService("Cuci Setrika","Rp 10.000/kg","Layanan cuci lengkap dengan setrika rapi.",R.drawable.cucisetrika, true),
        LaundryService("Setrika Saja","Rp 5.000/kg","Layanan khusus setrika pakaian saja.",R.drawable.setrika),
        LaundryService("Express 1 Hari","Rp 15.000/kg","Layanan cepat selesai dalam 1 hari.",R.drawable.express),
        LaundryService("Cuci Karpet","Rp 25.000/m²","Pencucian karpet bersih dan wangi.",R.drawable.cucikarpet)
    )

    Column(
        modifier = modifier
            .fillMaxSize()
            .padding(16.dp)
    ) {

        Text(
            text = "Kategori Layanan",
            style = MaterialTheme.typography.titleMedium
        )

        Spacer(modifier = Modifier.height(8.dp))

        CategorySection()

        Spacer(modifier = Modifier.height(12.dp))

        LazyColumn {

            items(listLaundry) { service ->

                LaundryCard(service)

                Spacer(modifier = Modifier.height(16.dp))
            }
        }
    }
}

@Composable
fun CategorySection() {

    val categories = listOf(
        "Semua",
        "Cuci",
        "Setrika",
        "Express",
        "Karpet"
    )

    LazyRow(
        modifier = Modifier.fillMaxWidth()
    ) {

        items(categories) { category ->

            Card(
                modifier = Modifier
                    .padding(end = 8.dp),
                shape = RoundedCornerShape(20.dp),
                colors = CardDefaults.cardColors(
                    containerColor = MaterialTheme.colorScheme.primary
                )
            ) {

                Text(
                    text = category,
                    modifier = Modifier.padding(12.dp),
                    color = MaterialTheme.colorScheme.onPrimary
                )
            }
        }
    }
}

@Composable
fun LaundryCard(service: LaundryService) {

    Card(
        modifier = Modifier.fillMaxWidth(),
        shape = RoundedCornerShape(16.dp),
        elevation = CardDefaults.cardElevation(8.dp)
    ) {

        Column {

            Image(
                painter = painterResource(service.imageRes),
                contentDescription = service.nama,
                contentScale = ContentScale.Crop,
                modifier = Modifier
                    .fillMaxWidth()
                    .height(160.dp)
            )

            Column(
                modifier = Modifier.padding(16.dp)
            ) {

                // 🔥 BEST SELLER BADGE
                if (service.isBestSeller) {
                    Card(
                        colors = CardDefaults.cardColors(
                            containerColor = MaterialTheme.colorScheme.secondary
                        ),
                        shape = RoundedCornerShape(8.dp)
                    ) {
                        Text(
                            text = "🔥 Best Seller",
                            modifier = Modifier.padding(horizontal = 8.dp, vertical = 4.dp),
                            color = MaterialTheme.colorScheme.onSecondary,
                            fontSize = 12.sp,
                            fontWeight = FontWeight.Bold
                        )
                    }

                    Spacer(modifier = Modifier.height(6.dp))
                }

                Text(
                    text = service.nama,
                    fontSize = 18.sp,
                    fontWeight = FontWeight.Bold
                )

                Spacer(modifier = Modifier.height(4.dp))

                Text(
                    text = service.harga,
                    color = MaterialTheme.colorScheme.primary,
                    fontWeight = FontWeight.SemiBold
                )

                Spacer(modifier = Modifier.height(6.dp))

                Text(
                    text = service.deskripsi,
                    fontSize = 13.sp
                )

                Spacer(modifier = Modifier.height(12.dp))

                Button(
                    onClick = { },
                    modifier = Modifier.fillMaxWidth()
                ) {
                    Text("Pesan Sekarang")
                }
            }
        }
    }
}

